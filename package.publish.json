    "./components/island-modal": "./components/island-modal/index.ts",
    "./components/island-modal/island-modal.vue": "./components/island-modal/island-modal.vue",
    "./components/island-scroll": "./components/island-scroll/index.ts",
    "./components/island-scroll/island-scroll.vue": "./components/island-scroll/island-scroll.vue",
    "./components/island-text": "./components/island-text/index.ts",
    "./components/island-text/island-text.vue": "./components/island-text/island-text.vue"
  }
