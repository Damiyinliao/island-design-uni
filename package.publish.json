  "description": "A lightweight uni-app component library built with Vue3 and TypeScript.",
  "main": "index.ts",
  "types": "index.ts",
  "keywords": [
    "island-design-uni",
    "uni-app",
    "component-library",
    "vue3",
    "typescript"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Damiyinliao/island-design-uni.git"
  },
  "engines": {
    "HBuilderX": "^3.8.7"
  },
